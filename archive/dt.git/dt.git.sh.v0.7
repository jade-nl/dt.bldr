# -------------------------------------------------------------------------- #
# --- Main ---
# ------------------------------------------------------------------ #
clear
# -------------------------------------------------------- #
# handle options given
while getopts ":rcpbnivh" OPTION
do
  case ${OPTION} in
    r) optClean="1" ;;
    c) optClone="1" ;;
    p) optPull="1" ;;
    b) optBuild="1" ;;
    v) optVerbose="1" ;;
    i) optInstall="1" ;;
    n) optNinja="1"
       cmakeGen="Ninja"
       ninjaIsUsed="yes" ;;
    h) _showHelp ;;
   \?) _showHelp ;;
  esac
done
# -------------------------------------------------------- #
# Are we sane enough?
# do not run script as root
[ "$EUID" -ne 0 ] || _errHndlr "user check failed" "run this script as a normal user"
# check if git is installed
[ `which git` ] || _errHndlr "git binary" "git is not installed."
# if both -c and -p are given use -p
[ ${optClone} = "1" ] && [ ${optPull} = "1" ] && optClone="0"
# check if ninja is installed (if optNinja is set)
if [ ${optNinja} -eq "1" ]
then
  [ `which ninja` ] || _errHndlr "ninja binary" "ninja is not installed."
fi
# -------------------------------------------------------- #
# if no opts are given
if [ "$#" -lt "1" ]
then
  # fall back to these:
  optClean="0"    # Remove content install dir -> NO
  optClone="0"    # Clone darktable            -> NO
  optPull="1"     # Pull darktable             -> YES
  optBuild="1"    # Build darktable            -> YES
  optVerbose="0"  # Be verbose after build     -> NO
  optInstall="1"  # Install darktable          -> YES
  optNinja="0"    # Use ninja                  -> NO
fi
# -------------------------------------------------------- #
# lets go already
_genLog "- - -> Run starts <- - -"
[ "${optClean}"   = "1" ] && _clnInstDir
[ "${optClone}"   = "1" ] && _gitClone
[ "${optPull}"    = "1" ] && _gitPull
[ "${optBuild}"   = "1" ] && _dtBuild
[ "${optInstall}" = "1" ] && _dtInstall
# -------------------------------------------------------------------------- #
# --- Cleanup ---
# ------------------------------------------------------------------ #
_genLog "- - - - -> Run ends <- - - - -"
exit 0
# -------------------------------------------------------------------------- #
# End
