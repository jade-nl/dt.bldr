#!/bin/bash
# -------------------------------------------------------------------------- #
# Author       : Jacques D. / Jade_NL
# -------------------------------------------------------------------------- #
# Syntax       : dt.git.sh <options>
# Options      : -r      Remove installed binaries et al.
#              : -c      Clone files from git repository
#              : -p      Pull update from git repository
#              : -b      Build darktable
#              : -i      Install darktable
#              : -n      Use ninja instead of make
#              : -v      Show extended information after using -b
#              : -h/-?   Show help
#              : If no options are given: -p -b -i are used.
# -------------------------------------------------------------------------- #
# Dependencies : git
#              : sudo needs to be set up for the user running this script
#              : ninja (only if -n is used)
# -------------------------------------------------------------------------- #
# Changes      : sep 29 2019 - First build
#              : sep 30 2019 - _dtBuild, no more double build
#                            - Seperated build from install
#              : oct 01 2019 - Added help section
#              :             - Added comments
#              :             - Added Ninja support
#              :             - Added CFLAGS_SCRIPT option
#              : oct 02 2019 - Added automated -j setting for make (cores -1)
#              : oct 03 2019 - Changed some variables to more intuitive names
#              :             - Added -v option (extended build info)
#              :             - Added BUILD_CMSTEST build option
#              :             - Code and text cleanup
#              : oct 04 2019 - Added possibility to set make's debug flags
#              :             - Added script version info
#              :             - Fixed a typo
#              :             - Removed a variable that isn't used anywhere.
# -------------------------------------------------------------------------- #
# Tested on    : debian - 10.1 (Buster)
#              : bash   - 5.0.3
#              : git    - 2.20.1
#              : gcc    - (Debian 8.3.0-6) 8.3.0
#              : cmake  - 3.13.4
#              : make   - GNU Make 4.2.1
#              : ninja  - 1.8.2
#              : ccache - 3.6
# -------------------------------------------------------------------------- #
# Set default behaviour:
#set -xv
set -u
umask 026
LANG=POSIX
LC_ALL=POSIX
export LANG LC_ALL
# -------------------------------------------------------------------------- #
# --- Variables ---
# ------------------------------------------------------------------ #
# Script core related
scriptVersion="0.7"
scriptName="$(basename ${0})"
# script directories
scriptDir="/home/gerber/bin"                                   # !! Change this !!
scriptLogDir="${scriptBaseDir}/Log"                             # !! Create this !!
# date format
fullDate="$(date '+%Y%m%d.%H%M')"
# logging
genLogFile="${scriptLogDir}/${scriptName%.*}.${fullDate}.log"   # script log
buildLog="${scriptLogDir}/dt.build.${fullDate}.log"             # cmake + make log
# define options
optClean="0"
optClone="0"
optPull="0"
optBuild="0"
optInstall="0"
optNinja="0"
ninjaIsUsed="no"
ccacheIsUsed="no"
optVerbose="0"
cmakeGen="Unix Makefiles"
# -------------------------------------------------------- #
# GIT related
baseGitDir="/opt/Git"                                  # !! Change this !!
dktbGitDir="${baseGitDir}/darktable"
# -------------------------------------------------------- #
# Build / install related
# darktable's install location
CMAKE_PREFIX_PATH="/opt/darktable"                              # !! Check/Change this !!
# ---> Check the DefineOptions.cmake file for the current defaults
USE_CAMERA_SUPPORT="ON"         # default -> ON
USE_NLS="ON"                    # default -> ON
USE_COLORD="ON"                 # default -> ON
USE_MAP="OFF"                    # default -> ON **
USE_LUA="ON"                    # default -> ON
DONT_USE_INTERNAL_LUA="ON"      # default -> ON
USE_FLICKR="OFF"                 # default -> ON **
USE_KWALLET="OFF"                # default -> ON **
USE_LIBSECRET="ON"              # default -> ON
USE_UNITY="OFF"                 # default -> OFF
USE_OPENMP="ON"                 # default -> ON
USE_OPENCL="OFF"                 # default -> ON **
USE_GRAPHICSMAGICK="ON"         # default -> ON
USE_DARKTABLE_PROFILING="OFF"   # default -> OFF
USE_XMLLINT="ON"                # default -> ON
USE_OPENJPEG="ON"               # default -> ON
USE_WEBP="ON"                   # default -> ON
USE_OPENEXR="ON"                # default -> ON
USE_LENSFUN="ON"                # default -> ON
BUILD_PRINT="OFF"                # default -> ON **
BUILD_BATTERY_INDICATOR="OFF"   # default -> OFF
BUILD_NOISE_TOOLS="OFF"         # default -> OFF
BUILD_CURVE_TOOLS="OFF"         # default -> OFF
BUILD_CMSTEST="ON"              # default -> ON
# -------------------------------------------------------- #
# cmake related options
# main choices are:
#   1) Debug 
#   2) Release
#   3) RelWithDebInfo
CMAKE_BUILD_TYPE="Release"
# -------------------------------------------------------- #
# Defaults flags for CMAKE_BUILD_TYPE are:
# CMAKE_C_FLAGS_DEBUG                -g
# CMAKE_CXX_FLAGS_DEBUG              -g
# CMAKE_C_FLAGS_RELEASE              -O3 -DNDEBUG
# CMAKE_CXX_FLAGS_RELEASE            -O3 -DNDEBUG
# CMAKE_C_FLAGS_RELWITHDEBINFO is    -O2 -g -DNDEBUG
# CMAKE_CXX_FLAGS_RELWITHDEBINFO is  -O2 -g -DNDEBUG
# --> https://www.brianlheim.com/2018/04/09/cmake-cheat-sheet.html
# There's no real need to add to or change the following.....
CFLAGS_SCRIPT=""
# -------------------------------------------------------- #
# make related options
# determine amount of cores present
numberCores="$( cat /proc/cpuinfo | grep -c "^processor" )"
coresToUse=$(( $numberCores - 1))         # use all but one cores
# use one of these three (no need to change this if not debugging)
makeOpts="-j ${coresToUse}"              # default
#makeOpts="--debug=b -j ${coresToUse}"    # basic debugging
#makeOpts="--debug=v -j ${coresToUse}"    # verbose debugging
# -------------------------------------------------------- #
curVers="n/a"
newVers=""
# Get current darktable version if available
[ -e ${CMAKE_PREFIX_PATH}/bin/darktable ] && \
  [ -x ${CMAKE_PREFIX_PATH}/bin/darktable ] && \
  curVers="$(${CMAKE_PREFIX_PATH}/bin/darktable --version | awk 'NR==1 { print $4 }')"
# -------------------------------------------------------------------------- #
# --- Functions ---
# ------------------------------------------------------------------ #
# Function : General logger
# ------------------------------------------------------------------ #
function _genLog ()
{
  # ---------------------------------------
  # log message to screen and to file, prefixed with date
  logMessage="$1"
  echo "$(date '+%Y%m%d %H:%M:%S') - ${logMessage}" >> ${genLogFile}
}
# ------------------------------------------------------------------ #
# Function : Error handler
# ------------------------------------------------------------------ #
function _errHndlr ()
{
  # ------------------
  # log error message.
  errorLocation="$1"
  errorMessage="$2"

  # -------
  # To file
  _genLog "FATAL ERROR: ${errorMessage}"

  #----------
  # To screen
  echo "
  A fatal error occured.

    Script   : ${scriptName}
    Function : ${errorLocation}
    Error    : ${errorMessage}

  Exiting now.
"
  exit 128
}
# ------------------------------------------------------------------ #
# Function : Removing darktables' installation files/directories
# ------------------------------------------------------------------ #
function _clnInstDir ()
{
  _genLog "- - -> Cleaning installation directory..."
  # Remove all files/subdirs from CMAKE_PREFIX_PATH
  echo -e "\nRemoving darktable from ${CMAKE_PREFIX_PATH}:\n"
  [ ! -d ${CMAKE_PREFIX_PATH} ] && _errHndlr "_clnInstDir" "${CMAKE_PREFIX_PATH}: directory doesn't exist"
  # needs root privileges
  sudo rm -rf ${CMAKE_PREFIX_PATH}/* || _errHndlr "_clnInstDir" "not able to clean ${CMAKE_PREFIX_PATH}"
}
# ------------------------------------------------------------------ #
# Function : Clone darktable and get submodules from git repository
# ------------------------------------------------------------------ #
function _gitClone ()
{
  _genLog "- - -> Cleaning darktable git directory..."
  echo -e "\nCloning darktable and modules:\n"
  # Remove all files from dktbGitDir
  [ ! -d ${baseGitDir} ] && _errHndlr "_gitClone" "${baseGitDir}: directory doesn't exist"
  if [ -d ${dktbGitDir} ]
  then
    find ${dktbGitDir} -mindepth 1 -delete || _errHndlr "_gitClone" "not able to clean ${dktbGitDir}"
  fi
  # get darktable
  _genLog "- - -> Cloning darktable..."
  cd ${baseGitDir}
  git clone git://github.com/darktable-org/darktable.git || _errHndlr "_gitClone" "git cloning failed"
  # get rawspeed
  _genLog "- - -> Initializing and updating rawspeed"
  cd ${dktbGitDir} || _errHndlr "_gitClone" "${dktbGitDir} doesn't exist"
  git submodule init || _errHndlr "_gitClone" "submodule init failed"
  git submodule update || _errHndlr "_gitClone" "submodule update failed"
  # show version
  echo ""
  echo "-----------------------------------------------"
  echo "- Installed version : ${curVers}"
  echo "- Cloned version    :" $( git describe | sed 's/release-//')
  echo ""
}
# ------------------------------------------------------------------ #
# Function : Pull update from git repository (darktable + rawspeed)
# ------------------------------------------------------------------ #
function _gitPull ()
{
  # updating darktable
  echo -e "\nUpdating darktable and modules:\n"
  cd ${dktbGitDir} || _errHndlr "_gitPull" "${dktbGitDir}: directory doesn't exist"
  _genLog "- - -> Updating darktable..."
  git pull || _errHndlr "_gitPull" "updating darktable failed"
  # updating rawspeed
  _genLog "- - -> Updating rawspeed..."
  git submodule update || _errHndlr "_gitPull" "updating rawspeed failed"
  # show version
  echo ""
  echo "-----------------------------------------------"
  echo "- Installed version  : ${curVers}"
  echo "- Git Pulled version :" $( cd ${dktbGitDir} ; git describe | sed 's/release-//')
  echo ""
}
# ------------------------------------------------------------------ #
# Function : Build darktable
# ------------------------------------------------------------------ #
function _dtBuild ()
{
  # start timer
  strtBldTime=$(date +%s)
  # build darktable
  _genLog "- - -> Building darktable..."
  cd ${dktbGitDir} || _errHndlr "_dtBuild" "${dktbGitDir}: directory doesn't exist"
  # make sure to have a clean build environment
  rm -rf build > /dev/null 2>&1
  # set up build environment
  mkdir build
  cd ${dktbGitDir}/build
  # run cmake
  cmake -DCMAKE_INSTALL_PREFIX="${CMAKE_PREFIX_PATH}" \
        -DCMAKE_BUILD_TYPE="${CMAKE_BUILD_TYPE}" \
        -DDONT_USE_INTERNAL_LUA="${DONT_USE_INTERNAL_LUA}" \
        -DUSE_CAMERA_SUPPORT="${USE_CAMERA_SUPPORT}" \
        -DUSE_COLORD="${USE_COLORD}" \
        -DUSE_DARKTABLE_PROFILING="${USE_DARKTABLE_PROFILING}" \
        -DUSE_FLICKR="${USE_FLICKR}" \
        -DUSE_GRAPHICSMAGICK="${USE_GRAPHICSMAGICK}" \
        -DUSE_KWALLET="${USE_KWALLET}" \
        -DUSE_LENSFUN="${USE_LENSFUN}" \
        -DUSE_LIBSECRET="${USE_LIBSECRET}" \
        -DUSE_LUA="${USE_LUA}" \
        -DUSE_MAP="${USE_MAP}" \
        -DUSE_NLS="${USE_NLS}" \
        -DUSE_OPENCL="${USE_OPENCL}" \
        -DUSE_OPENEXR="${USE_OPENEXR}" \
        -DUSE_OPENJPEG="${USE_OPENJPEG}" \
        -DUSE_OPENMP="${USE_OPENMP}" \
        -DUSE_UNITY="${USE_UNITY}" \
        -DUSE_WEBP="${USE_WEBP}" \
        -DUSE_XMLLINT="${USE_XMLLINT}" \
        -DBUILD_PRINT="${BUILD_PRINT}" \
        -DBUILD_BATTERY_INDICATOR="${BUILD_BATTERY_INDICATOR}" \
        -DBUILD_NOISE_TOOLS="${BUILD_NOISE_TOOLS}" \
        -DBUILD_CURVE_TOOLS="${BUILD_CURVE_TOOLS}" \
        -DBUILD_CMSTEST=${BUILD_CMSTEST} \
        CFLAGS_SCRIPT="${CFLAGS_SCRIPT}" \
        CXXFLAGS_SCRIPT="${CFLAGS_SCRIPT}" \
        -G "${cmakeGen}" \
        .. 2>&1 | tee -a ${buildLog} || _errHndlr "_dtBuild" "cmake failed"
  # run make or ninja
  if [ ${optNinja} -eq "0" ]
  then
    # use make
    make ${makeOpts} 2>&1 | tee -a ${buildLog} || _errHndlr "_dtBuild" "make failed"
  else
    # use ninja
    ninja ${makeOpts} 2>&1 | tee -a ${buildLog} || _errHndlr "_dtBuild" "ninja failed"
  fi
  # end timer + set runtime
  endBldTime=$(date +%s)
  runTime=$(($endBldTime - $strtBldTime))
  # get version info
  newVers=$(  cd ${dktbGitDir} ; git describe | sed 's/release-//' )
  # is extra info requested
  if [ ${optVerbose} -eq "1" ]
  then
    # get and write extended info
    echo -e "\n---------------------------------------------------------" | tee -a ${buildLog}
    echo "- release and build environment information:" | tee -a ${buildLog}
    echo "---------------------------------------------------------" | tee -a ${buildLog}
    echo "dt.git.sh scriptVersion" | tee -a ${buildLog}
    gcc --version | awk '/^gcc /{ print }' | tee -a ${buildLog}
    g++ --version | awk '/^g\+\+ /{ print }' | tee -a ${buildLog}
    cmake --version | awk '/^cmake /{ print }' | tee -a ${buildLog}
    make --version | awk '/[Mm]ake /{ print }' | tee -a ${buildLog}
    [ $( which ninja ) ] && echo -n "ninja " ; ninja --version | tee -a ${buildLog}
    echo "  - is ninja used : ${ninjaIsUsed}" | tee -a ${buildLog}
    if [ $( which ccache) ]
    then
      [ $( which ccache ) ] && ccache --version | awk '/^ccache /{ print }' | tee -a ${buildLog}
      [ ${PATH%%:*} == "/usr/lib/ccache" ] && ccacheIsUsed="Probably"
      echo "  - is ccache used : ${ccacheIsUsed}" | tee -a ${buildLog}
    fi
  { cat |  tee -a ${buildLog}; } <<EOF
---------------------------------------------------------
- cmake options [defaults followed by user setting]
---------------------------------------------------------
CMAKE_PREFIX_PATH             = ${CMAKE_PREFIX_PATH}
CFLAGS_SCRIPT                 = ${CFLAGS_SCRIPT}
CXXFLAGS_SCRIPT               = ${CFLAGS_SCRIPT}
USE_CAMERA_SUPPORT ...... ON  = ${USE_CAMERA_SUPPORT}
USE_COLORD .............. ON  = ${USE_COLORD}
USE_DARKTABLE_PROFILING . OFF = ${USE_DARKTABLE_PROFILING}
USE_FLICKR .............. ON  = ${USE_FLICKR}
USE_GRAPHICSMAGICK ...... ON  = ${USE_GRAPHICSMAGICK}
USE_KWALLET ............. ON  = ${USE_KWALLET}
USE_LENSFUN ............. ON  = ${USE_LENSFUN}
USE_LIBSECRET ........... ON  = ${USE_LIBSECRET}
USE_LUA ................. ON  = ${USE_LUA}
DONT_USE_INTERNAL_LUA ... ON  = ${DONT_USE_INTERNAL_LUA}
USE_MAP ................. ON  = ${USE_MAP}
USE_NLS ................. ON  = ${USE_NLS}
USE_OPENCL .............. ON  = ${USE_OPENCL}
USE_OPENEXR ............. ON  = ${USE_OPENEXR}
USE_OPENJPEG ............ ON  = ${USE_OPENJPEG}
USE_OPENMP .............. ON  = ${USE_OPENMP}
USE_UNITY ............... OFF = ${USE_UNITY}
USE_WEBP ................ ON  = ${USE_WEBP}
USE_XMLLINT ............. ON  = ${USE_XMLLINT}
BUILD_BATTERY_INDICATOR . OFF = ${BUILD_BATTERY_INDICATOR}
BUILD_CMSTEST ........... ON  = ${BUILD_CMSTEST}
BUILD_CURVE_TOOLS ....... OFF = ${BUILD_CURVE_TOOLS}
BUILD_NOISE_TOOLS ....... OFF = ${BUILD_NOISE_TOOLS}
BUILD_PRINT ............. ON  = ${BUILD_PRINT}
---------------------------------------------------------
- make/ninja options
---------------------------------------------------------
make / ninja                  = ${makeOpts}
EOF
  fi
  # print darktable version info
  echo "---------------------------------------------------------" | tee -a ${buildLog}
  echo "- Installed version : ${curVers}" | tee -a ${buildLog}
  echo "- Build version     : ${newVers}" | tee -a ${buildLog}
  echo "---------------------------------------------------------" | tee -a ${buildLog}
  # print build time
  printf '%-22s%02dh:%02dm:%02ds\n\n' "- Buildtime         :" $(($runTime/3600)) $(($runTime%3600/60)) $(($runTime%60)) | tee -a ${buildLog}
  echo ""
}
# ------------------------------------------------------------------ #
# Function : Install darktable
# ------------------------------------------------------------------ #
function _dtInstall ()
{
  _genLog "- - -> Installing darktable"
  # install darktable
  echo -e "\nInstalling darktable:\n"
  cd ${dktbGitDir}/build || _errHndlr "_dtInstall" "${dktbGitDir}/build: directory doesn't exist"
  [ -z ${newVers} ] && newVers=$( cd ${dktbGitDir} ; git describe | sed 's/release-//' )
  # set normal permissions for installation process
  umask 022
  # needs root privileges
  if [ ${optNinja} -eq "0" ]
  then
    # use make
    useNinja="no"
    sudo make install || _errHndlr "_dtInstall" "make install failed"
  else
    # use ninja
    useNinja="yes"
    sudo ninja install || _errHndlr "_dtInstall" "ninja install failed"
  fi
  # back to more restrictive mode
  umask 026
  # print darktable version info
  [ -z ${curVers}] ] && curVers="n/a"
  echo ""
  echo "-----------------------------------------------"
  echo "- Previous version        : ${curVers}"
  echo "- Newly installed version : ${newVers}"
  echo ""
}
# ------------------------------------------------------------------ #
# Function : Show help
# ------------------------------------------------------------------ #
